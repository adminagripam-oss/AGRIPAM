# ============================================================
# Environment Variables — AGRI-PAM Supabase
# Salin file ini ke .env dan isi nilainya
# JANGAN commit file .env ke GitHub!
# ============================================================

# URL Supabase project Anda
SUPABASE_URL=https://wcocmwkccntmmtlofowe.supabase.co

# Service Role Key (bukan anon key!) — dari Supabase Dashboard > Settings > API
# RAHASIA: jangan pernah expose ke frontend / publik
SUPABASE_SERVICE_KEY=your_service_role_key_here

# JWT Secret — minimal 64 karakter random
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_secret_here
